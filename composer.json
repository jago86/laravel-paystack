{
    "name": "unicodeveloper/laravel-paystack",
    "description": "A Laravel Package for Paystack",
    "keywords": [
        "php",
        "github",
        "laravel",
        "Open Source",
        "payments",
        "subscription",
        "paystack",
        "paystack.co",
        "laravel 12",
        "laravel 13"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "unicodeveloper",
            "email": "prosperotemuyiwa@gmail.com"
        },
        {
            "name": "iamfunsho",
            "email": "info@devfunsho.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.8|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5|^12.0",
        "scrutinizer/ocular": "~1.1",
        "php-coveralls/php-coveralls": "^2.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "files": [
            "src/Support/helpers.php"
        ],
        "psr-4": {
            "Unicodeveloper\\Paystack\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Unicodeveloper\\Paystack\\Test\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Unicodeveloper\\Paystack\\PaystackServiceProvider"
            ],
            "aliases": {
                "Paystack": "Unicodeveloper\\Paystack\\Facades\\Paystack"
            }
        }
    }
}
